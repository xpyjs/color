{
  "name": "@xpyjs/color",
  "version": "1.0.1",
  "private": false,
  "type": "module",
  "description": "A tiny, fast, and plugin-extensible color manipulation library for JavaScript/TypeScript.",
  "main": "dist/index.cjs",
  "module": "dist/index.esm.js",
  "browser": "dist/index.umd.js",
  "unpkg": "dist/index.umd.js",
  "jsdelivr": "dist/index.umd.js",
  "types": "dist/types/index.d.ts",
  "typesVersions": {
    "*": {
      "plugins/*": [
        "dist/types/plugins/*/index.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "browser": "./dist/index.umd.js",
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs"
    },
    "./plugins/*": {
      "types": "./dist/types/plugins/*/index.d.ts",
      "import": "./dist/plugins/*/index.js",
      "require": "./dist/plugins/*/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run clean && rollup -c",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run build",
    "clean": "rimraf dist",
    "create:plugin": "node scripts/create-plugin.mjs",
    "docs:dev": "vitepress dev docs",
    "docs:build": "npm run build && vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "release": "npm test && npm version patch",
    "release:minor": "npm test && npm version minor",
    "release:major": "npm test && npm version major",
    "release:alpha": "npm test && npm version prerelease --preid=alpha",
    "release:beta": "npm test && npm version prerelease --preid=beta"
  },
  "keywords": [
    "color",
    "colour",
    "rgb",
    "hsl",
    "hsv",
    "hex",
    "css",
    "manipulation",
    "tiny",
    "plugin",
    "typescript"
  ],
  "author": "xpyjs",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xpyjs/color.git"
  },
  "homepage": "https://github.com/xpyjs/color#readme",
  "bugs": {
    "url": "https://github.com/xpyjs/color/issues"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=14.0.0"
  },
  "browserslist": [
    "> 0.25%",
    "not dead"
  ],
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@rollup/plugin-babel": "^6.1.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.2",
    "@vitest/coverage-v8": "^3.0.5",
    "markdown-it-mathjax3": "4",
    "rimraf": "^6.0.1",
    "rollup": "^4.30.1",
    "rollup-plugin-dts": "^6.1.1",
    "sandpack-vue3": "^3.1.12",
    "tslib": "^2.8.1",
    "typescript": "^5.7.3",
    "vitepress": "^1.6.4",
    "vitest": "^3.0.5"
  }
}
